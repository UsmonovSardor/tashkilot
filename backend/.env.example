APP_NAME="VelvetHour"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-api.up.railway.app

LOG_CHANNEL=stderr
LOG_LEVEL=error

# Railway injects DATABASE_URL automatically when you add PostgreSQL service
# These are fallbacks if you prefer individual vars:
DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=railway
DB_USERNAME=postgres
DB_PASSWORD=

CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# Railway injects REDIS_URL automatically when you add Redis service
REDIS_URL=
REDIS_HOST=
REDIS_PASSWORD=
REDIS_PORT=6379

# JWT
JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160

# Stripe
STRIPE_KEY=pk_live_xxx
STRIPE_SECRET=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# OpenAI
OPENAI_API_KEY=sk-xxx

# Platform config
PLATFORM_FEE_PERCENT=15
ESCROW_AUTO_RELEASE_HOURS=48
