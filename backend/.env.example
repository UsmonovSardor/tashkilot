APP_NAME="VelvetHour"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=velvethour
DB_USERNAME=postgres
DB_PASSWORD=

CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM_ADDRESS="hello@velvethour.com"
MAIL_FROM_NAME="VelvetHour"

# JWT
JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160

# Stripe
STRIPE_KEY=pk_test_xxx
STRIPE_SECRET=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PLATFORM_FEE_PERCENT=15

# OpenAI (for companion AI matching)
OPENAI_API_KEY=sk-xxx
OPENAI_ORGANIZATION=org-xxx

# App settings
PLATFORM_FEE_PERCENT=15
ESCROW_AUTO_RELEASE_HOURS=48
